{
  "name": "waqupin",
  "version": "0.1.0",
  "description": "AI小说写作插件 - 支持百万字级别记忆管理",
  "ai_model": {
    "default_provider": "openai",
    "api_key": "YOUR_API_KEY_HERE",
    "model": "gpt-4",
    "temperature": 0.7,
    "max_tokens": 2000
  },
  "memory": {
    "enabled": true,
    "storage_type": "sqlite",
    "database_path": "./data/memory.db",
    "max_context_length": 100000,
    "summary_enabled": true
  },
  "writing_rules": {
    "max_chapter_length": 3000,
    "style_consistency": true,
    "character_consistency": true,
    "plot_tracking": true
  },
  "prompts": {
    "system_prompt": "你是一个专业的小说作家助手，请保持角色一致性和情节连贯性。",
    "writing_style": "请使用流畅自然的中文写作，注意细节描写。",
    "constraints": [
      "不要让角色突然改变性格",
      "保持时间线的连贯性",
      "避免重复使用相同的情节"
    ]
  },
  "reference_novels": {
    "enabled": false,
    "storage_path": "./data/references/",
    "use_for_style": true,
    "use_for_plot": false
  },
  "output": {
    "format": "markdown",
    "auto_save": true,
    "save_path": "./output/",
    "backup_enabled": true
  }
}
